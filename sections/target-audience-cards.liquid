        {
          "type": "card",
          "settings": {
            "list_item_1": "Distributors",
            "list_item_2": "Agencies",
            "list_item_3": "Trade Pros.",
            "card_description": "You've already got the clients."
          }
        }
      ]
    }
  ]
}
{% endschema %}
