<div class="padding-global under-hood_bg-wrapper">
   {% if section.settings.cta_image != blank %}
   <div class="under-hood_bg-image" style="background-image: url({{ section.settings.cta_image | image_url: width: 1600 }});"></div>
   {% endif %}
   <div class="container-large">
      <div class="padding-section-large">
         <div class="under-hood_component">
            
            <!-- Section Header -->
            <div class="under-hood_header">
               
               {% if section.settings.section_heading != blank %}
               <h2 li-object="section.settings.section_heading" class="under-hood_heading heading-style-h2">
                  {{ section.settings.section_heading }}
               </h2>
               {% endif %}
               
               {% if section.settings.section_subtitle != blank %}
               <p li-object="section.settings.section_subtitle" class="under-hood_subtitle">
                  {{ section.settings.section_subtitle }}
               </p>
               {% endif %}
            </div>
            
            <!-- Cards Grid -->
            <div class="under-hood_grid-wrapper">
               <div class="under-hood_grid">
                  {% for block in section.blocks %}
                     {% if block.type == 'card' %}
                     <div class="under-hood_card" 
                          style="background-color: {{ block.settings.card_bg_color }}; grid-column: span {{ block.settings.card_width }}; grid-row: span {{ block.settings.card_height }};"
                          {{ block.shopify_attributes }}>
                        
                        {% if block.settings.card_image != blank %}
                        <div class="under-hood_card-image">
                           <img li-object:src="block.settings.card_image | image_url: width: 800" 
                                src="{{ block.settings.card_image | image_url: width: 800 }}" 
                                alt="{{ block.settings.card_title }}"
                                width="800"
                                height="600"
                                loading="lazy"
                                class="under-hood_image">
                        </div>
                        {% endif %}
                        
                        <div class="under-hood_card-content" style="color: {{ block.settings.text_color }};">
                           {% if block.settings.card_title != blank %}
                           <h3 li-object="block.settings.card_title" class="under-hood_card-title">
                              {{ block.settings.card_title }}
                           </h3>
                           {% endif %}
                           
                           {% if block.settings.card_description != blank %}
                           <p li-object="block.settings.card_description" class="under-hood_card-description">
                              {{ block.settings.card_description }}
                           </p>
                           {% endif %}
                        </div>
                     </div>
                     {% endif %}
                  {% endfor %}
               </div>
            </div>
            
            <!-- Bottom CTA Section -->
            {% if section.settings.show_bottom_cta %}
            <div class="under-hood_cta-section">
               <div class="under-hood_cta-content">
                  {% if section.settings.cta_heading != blank %}
                  <h3 li-object="section.settings.cta_heading" class="heading-style-h3 under-hood_cta-heading">
                     {{ section.settings.cta_heading }}
                  </h3>
                  {% endif %}
                  
                  <div class="under-hood_animated-text" data-texts="We're authentic.|We're creative.|We're bold.|We're reliable AF."><span class="under-hood_cursor">|</span></div>
                  
                  {% if section.settings.cta_text != blank %}
                  <p li-object="section.settings.cta_text" class="under-hood_cta-text">
                     {{ section.settings.cta_text }}
                  </p>
                  {% endif %}
                  
                  <div class="under-hood_button-wrapper button-group">
                     {% render 'button' %}
                  </div>
               </div>
            </div>
            {% endif %}
            
         </div>
      </div>
   </div>
</div>

<script>
(function() {
  const animatedText = document.querySelector('.under-hood_animated-text');
  if (!animatedText) return;
  
  const cursor = animatedText.querySelector('.under-hood_cursor');
  const texts = animatedText.dataset.texts.split('|');
  let currentIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  
  function typeWriter() {
    const currentText = texts[currentIndex];
    
    if (!isDeleting) {
      // Typing
      const displayText = currentText.substring(0, charIndex + 1);
      animatedText.innerHTML = displayText + cursor.outerHTML;
      charIndex++;
      
      if (charIndex === currentText.length) {
        // Pause at end of text
        setTimeout(() => { isDeleting = true; typeWriter(); }, 2000);
        return;
      }
    } else {
      // Deleting
      const displayText = currentText.substring(0, charIndex - 1);
      animatedText.innerHTML = displayText + cursor.outerHTML;
      charIndex--;
      
      if (charIndex === 0) {
        isDeleting = false;
        currentIndex = (currentIndex + 1) % texts.length;
        setTimeout(typeWriter, 500);
        return;
      }
    }
    
    setTimeout(typeWriter, isDeleting ? 50 : 100);
  }
  
  // Start animation
  typeWriter();
})();
</script>

{% style %}
.under-hood_bg-wrapper {
   position: relative;
}

.under-hood_bg-image {
   position: absolute;
   top: 30%;
   left: 30%;
   right: 0;
   bottom: 0;
   background-size: cover;
   background-position: center;
   background-repeat: no-repeat;
   z-index: 0;
}

.under-hood_bg-image::before {
   content: '';
   position: absolute;
   inset: 0;
   background: 
      linear-gradient(90deg, #FDFAF5 0%, rgba(253, 250, 245, 0.00) 100%),
      linear-gradient(to bottom, #ffffff 0%, rgba(255, 255, 255, 0) 20%);
      
   pointer-events: none;
}

.under-hood_bg-wrapper > .container-large {
   position: relative;
   z-index: 1;
}

.under-hood_component {
   width: 100%;
}

/* Header Styles */
.under-hood_header {
   text-align: center;
   margin-bottom: 60px;
}

.under-hood_badge {
   display: inline-block;
   background-color: #EF4444;
   color: white;
   font-size: 0.875rem;
   font-weight: 600;
   padding: 6px 16px;
   border-radius: 6px;
   margin-bottom: 20px;
}

.under-hood_heading {
   margin: 0 0 20px 0;
}

.under-hood_subtitle {
  color: var(--GRAY-TEXT, #314958);
   font-size: 20px;
   line-height: 25px;
   max-width: 800px;
   font-weight: 400;
   margin: 0 auto;
}

/* Cards Grid - Bento Box Layout */
.under-hood_grid-wrapper {
   position: relative;
   padding: 20px;
   margin-bottom: 40px;
}

.under-hood_grid {
   display: grid;
   grid-template-columns: repeat(4, 1fr);
   grid-auto-rows: 280px;
   gap: 20px;
   position: relative;
   z-index: 2;
}

.under-hood_card {
   border-radius: 24px;
   overflow: hidden;
   position: relative;
   padding: 32px;
   display: flex;
   flex-direction: column;
   justify-content: flex-end;
   transition: transform 0.3s ease;
}

.under-hood_card:hover {
   transform: translateY(-4px);
}

.under-hood_card-image {
   position: absolute;
   inset: 0;
   width: 100%;
   height: 100%;
   z-index: 0;
}

.under-hood_image {
   width: 100%;
   height: 100%;
   object-fit: cover;
   display: block;
   background-color: initial;
}

.under-hood_card-content {
   position: relative;
   z-index: 1;
   margin-top: auto;
}

.under-hood_card-title {
   font-size: 1.75rem;
   font-weight: 400;
   line-height: 1.3;
   margin: 0 0 12px 0;
   text-transform: inherit;
   color: white;
}

.under-hood_card-description {
   font-size: 1rem;
   line-height: 1.5;
   margin: 0;
   opacity: 0.95;
}

/* CTA Section */
.under-hood_cta-section {
   border-radius: 24px;
   padding: 60px 10px;
   display: grid;
   grid-template-columns: 1fr 1.5fr;
   gap: 10px;
   align-items: center;
   position: relative;
   overflow: hidden;
}

.under-hood_cta-content {
   position: relative;
   z-index: 2;
}
.under-hood_cta-heading {
   text-transform: initial;
   margin: 0 0 24px 0;
   color: #000;
}

.under-hood_animated-text {
   font-size: 3.5rem;
   font-weight: 700;
   line-height: 1.2;
   color: #000;
   min-height: 80px;
   display: flex;
   align-items: center;
   margin-bottom: 24px;
}

.under-hood_cursor {
   font-weight: 400;
   animation: blink 1s infinite;
   margin-left: 2px;
}

@keyframes blink {
   0%, 50% { opacity: 1; }
   51%, 100% { opacity: 0; }
}

.under-hood_cta-text {
  color: var(--GRAY-TEXT, #314958);
   font-size: 20px;
   line-height: 25px;
   font-weight: 400;
   margin: 0 0 32px 0;
}

.under-hood_cta-button {
   display: inline-block;
   background-color: #FF6B35;
   color: white;
   font-size: 1rem;
   font-weight: 600;
   padding: 16px 32px;
   border-radius: 50px;
   text-decoration: none;
   transition: background-color 0.3s ease, transform 0.2s ease;
}

.under-hood_cta-button:hover {
   background-color: #E85A2A;
   transform: translateY(-2px);
}

/* Tablet */
@media (max-width: 991px) {
     
   .under-hood_grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 240px;
      gap: 16px;
   }
   
   .under-hood_card {
      padding: 24px;
   }
   
   .under-hood_card-title {
      font-size: 1.5rem;
   }
   
   .under-hood_cta-section {
      padding: 40px;
      gap: 40px;
   }
   
   .under-hood_cta-heading {
      font-size: 2rem;
   }
}

/* Mobile */
@media (max-width: 767px) {
   .under-hood_header {
      margin-bottom: 40px;
   }
   
   .under-hood_subtitle {
      font-size: 1rem;
   }
   
   .under-hood_grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
      gap: 12px;
      margin-bottom: 40px;
   }
   
   .under-hood_card {
      padding: 24px;
      grid-column: span 1 !important;
      grid-row: span 1 !important;
   }
   
   .under-hood_card-title {
      font-size: 1.25rem;
   }
   
   .under-hood_card-description {
      font-size: 0.9rem;
   }
   
   .under-hood_cta-section {
      grid-template-columns: 1fr;
      padding: 32px;
      gap: 32px;
   }
   
   .under-hood_cta-image {
      position: relative;
      width: 100%;
      height: 300px;
   }
   
   .under-hood_cta-heading {
      font-size: 1.75rem;
   }
   
   .under-hood_cta-text {
      font-size: 1rem;
   }
}

@media (max-width: 479px) {
   .under-hood_grid {
      grid-auto-rows: 200px;
   }
   
   .under-hood_card {
      padding: 20px;
   }
   
   .under-hood_cta-section {
      padding: 24px;
   }
   
   .under-hood_cta-button {
      width: 100%;
      text-align: center;
   }
}
{% endstyle %}

