<div class="hero-statement_component">
   <div class="hero-statement_wrapper">
      <!-- Background Image -->
      <div class="hero-statement_background">
         <img li-object:src="section.settings.hero_image_1 | image_url: width: 1920" 
              loading="eager" 
              alt="" 
              width="1920"
              height="800"
              src="{{ section.settings.hero_image_1 | image_url: width: 1920 }}" 
              class="hero-statement_bg-image">
         <div class="hero-statement_overlay"></div>
      </div>
      
      <!-- Content Overlay -->
      <div class="hero-statement_content">
         <div class="hero-statement_content-wrapper">
            <h1 li-object="section.settings.hero_heading_text" class="hero-statement_heading">
               {{ section.settings.hero_heading_text }}
            </h1>
            <div class="hero-statement_paragraph">
               <div li-object="section.settings.hero_paragraph_text">
                  {{ section.settings.hero_paragraph_text }}
               </div>
            </div>
            <div class="hero-statement_button-wrapper button-group">
               {% render 'button' %}
            </div>
         </div>
      </div>
   </div>
</div>

{% style %}
.hero-statement_component {
   width: 100%;
   position: relative;
}

.hero-statement_wrapper {
   position: relative;
   width: 100%;
   min-height: 600px;
   height: 100vh;
   max-height: 800px;
   overflow: hidden;
}

.hero-statement_background {
   position: absolute;
   top: 0;
   left: 0;
   width: 100%;
   height: 100%;
   z-index: 1;
}

.hero-statement_bg-image {
   width: 100%;
   height: 100%;
   object-fit: cover;
   display: block;
   background-color: transparent;
}

.hero-statement_overlay {
   position: absolute;
   top: 0;
   left: 0;
   width: 100%;
   height: 100%;
   /* background: rgba(0, 0, 0, 0.4); */
   z-index: 2;
}

.hero-statement_content {
   position: relative;
   z-index: 3;
   width: 100%;
   height: 100%;
   display: flex;
   align-items: end;
   justify-content: center;
   padding: 60px 20px;
}

.hero-statement_content-wrapper {
   max-width: 1100px;
   text-align: center;
   color: white;
}

.hero-statement_heading {
   font-size: clamp(3rem, 8vw, 8rem);
   font-weight: 700;
   color: white;
   line-height: 0.95;
   margin-bottom: 30px;
   text-transform: uppercase;
   letter-spacing: -0.02em;
}

.hero-statement_paragraph {
   font-size: clamp(1rem, 1.5vw, 1.25rem);
   line-height: 1.6;
   color: white;
   margin: 0 auto 40px;
   max-width: 900px;
   font-weight: 400;
}

.hero-statement_paragraph p {
   margin-bottom: 15px;
}

.hero-statement_button-wrapper {
   display: flex;
   justify-content: center;
   align-items: center;
}

/* Tablet and Mobile */
@media (max-width: 991px) {
   .hero-statement_wrapper {
      min-height: 500px;
      max-height: 700px;
   }
   
   .hero-statement_content {
      padding: 40px 20px;
   }
   
   .hero-statement_heading {
      margin-bottom: 25px;
   }
   
   .hero-statement_paragraph {
      margin-bottom: 35px;
   }
}

@media (max-width: 767px) {
   .hero-statement_wrapper {
      min-height: 450px;
      max-height: 600px;
   }
   
   .hero-statement_content {
      padding: 30px 15px;
   }
   
   .hero-statement_heading {
      margin-bottom: 20px;
   }
   
   .hero-statement_paragraph {
      font-size: 1rem;
      margin-bottom: 30px;
   }
}

@media (max-width: 479px) {
   .hero-statement_wrapper {
      min-height: 400px;
      height: 90vh;
      max-height: 550px;
   }
   
   .hero-statement_content {
      padding: 25px 15px;
   }
   
   .hero-statement_paragraph {
      margin-bottom: 25px;
   }
}
{% endstyle %}

